---
import '@fontsource-variable/geist-mono'

const title = 'krmznkr — full-stack software engineer'
const description =
  'krmznkr — a full-stack software engineer based in Berlin. Calm, careful software, built in the open.'
const url = 'https://me.krmznkr.com'

const links = [
  { label: 'GitHub', href: 'https://github.com/krmznkr', note: 'code' },
  { label: 'Julian', href: 'https://julian.krmznkr.com', note: 'a calm calendar' },
  { label: 'Life', href: 'https://life.krmznkr.com', note: 'life in weeks' },
]
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08090c" />
    <meta name="color-scheme" content="dark" />

    <link rel="canonical" href={url} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:image" content={`${url}/og.svg`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${url}/og.svg`} />
  </head>

  <body>
    <canvas id="field" aria-hidden="true"></canvas>
    <div class="grain" aria-hidden="true"></div>

    <main>
      <header class="topbar">
        <span class="mark">
          <span class="dot" aria-hidden="true"></span>
          krmznkr
        </span>
        <span class="loc">Berlin · UTC+1</span>
      </header>

      <section class="hero">
        <p class="eyebrow" data-type>Hey — my name is</p>
        <h1>
          <span class="name" data-type>krmznkr</span><span class="cursor" aria-hidden="true"></span>
        </h1>
        <p class="lede" data-type>
          I'm a full-stack software engineer based in Berlin. I build calm,
          careful software and share it in the open.
        </p>

        <nav class="links" aria-label="Elsewhere">
          {
            links.map((l) => (
              <a href={l.href} rel="me noopener" target="_blank">
                <span class="l-label">{l.label}</span>
                <span class="l-note">{l.note}</span>
                <span class="l-arrow" aria-hidden="true">→</span>
              </a>
            ))
          }
        </nav>
      </section>

      <footer class="footer">
        <span>Open source</span>
        <span aria-hidden="true">·</span>
        <a href="https://github.com/krmznkr/me" rel="noopener" target="_blank">this page</a>
      </footer>
    </main>

    <script>
      import { startDitherField } from '../scripts/dither-field'

      const canvas = document.getElementById('field') as HTMLCanvasElement | null
      if (canvas) startDitherField(canvas)

      // Progressive-enhancement typewriter. Text is already in the DOM for
      // no-JS / crawlers; here we clear it and type it back out.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches
      const nodes = Array.from(
        document.querySelectorAll<HTMLElement>('[data-type]'),
      )
      const cursor = document.querySelector<HTMLElement>('.cursor')

      if (reduce || nodes.length === 0) {
        document.body.classList.add('typed')
      } else {
        const items = nodes.map((el) => ({ el, text: el.textContent ?? '' }))
        for (const it of items) it.el.textContent = ''

        const typeInto = (el: HTMLElement, text: string) =>
          new Promise<void>((resolve) => {
            let i = 0
            const step = () => {
              el.textContent = text.slice(0, i)
              if (i++ <= text.length) {
                const ch = text[i - 2] ?? ''
                const pause =
                  ch === '.' || ch === ',' ? 150 : 18 + Math.random() * 42
                window.setTimeout(step, pause)
              } else {
                resolve()
              }
            }
            step()
          })

        const wait = (ms: number) =>
          new Promise((r) => window.setTimeout(r, Math.max(0, ms)))

        const run = async () => {
          for (const it of items) {
            await typeInto(it.el, it.text)
            await wait(200)
          }
          document.body.classList.add('typed')
          cursor?.classList.add('rest')
        }
        void run()
      }
    </script>

    <style is:global>
      :root {
        --bg: #08090c;
        --fg: #e7e9f0;
        --muted: #8b8f9c;
        --faint: #4a4d57;
        --line: rgba(231, 233, 240, 0.1);
        color-scheme: dark;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        margin: 0;
        padding: 0;
        height: 100%;
      }

      body {
        background: var(--bg);
        color: var(--fg);
        font-family: 'Geist Mono Variable', ui-monospace, 'SF Mono', Menlo,
          monospace;
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        overflow: hidden;
        min-height: 100dvh;
      }

      #field {
        position: fixed;
        inset: 0;
        width: 100%;
        height: 100%;
        display: block;
        z-index: 0;
      }

      /* Soft vignette + faint scanlines layered over the pixels for depth. */
      .grain {
        position: fixed;
        inset: 0;
        z-index: 1;
        pointer-events: none;
        background:
          radial-gradient(
            120% 90% at 50% 42%,
            transparent 40%,
            rgba(0, 0, 0, 0.35) 82%,
            rgba(0, 0, 0, 0.72) 100%
          ),
          repeating-linear-gradient(
            0deg,
            rgba(0, 0, 0, 0.16) 0px,
            rgba(0, 0, 0, 0.16) 1px,
            transparent 1px,
            transparent 3px
          );
        mix-blend-mode: multiply;
      }

      main {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        min-height: 100dvh;
        padding: clamp(1.25rem, 4vw, 3rem);
        padding-top: max(clamp(1.25rem, 4vw, 3rem), env(safe-area-inset-top));
        padding-bottom: max(
          clamp(1.25rem, 4vw, 3rem),
          env(safe-area-inset-bottom)
        );
      }

      .topbar {
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-size: 0.72rem;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        color: var(--muted);
      }

      .mark {
        display: inline-flex;
        align-items: center;
        gap: 0.55em;
        color: var(--fg);
      }

      .dot {
        width: 7px;
        height: 7px;
        background: var(--fg);
        box-shadow: 0 0 0 2px rgba(231, 233, 240, 0.12);
        animation: blink 3.4s steps(1) infinite;
      }

      .loc {
        color: var(--faint);
      }

      .hero {
        margin: auto 0;
        max-width: 46ch;
        text-shadow: 0 1px 18px rgba(0, 0, 0, 0.45);
      }

      .eyebrow {
        margin: 0 0 0.9rem;
        min-height: 1.2em;
        font-size: clamp(0.8rem, 2.2vw, 1rem);
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--muted);
      }

      h1 {
        margin: 0;
        font-weight: 500;
        line-height: 1;
        letter-spacing: -0.02em;
        font-size: clamp(3.1rem, 15vw, 8.5rem);
        white-space: nowrap;
      }

      .name {
        background: linear-gradient(
          180deg,
          #ffffff 0%,
          #c7cad4 55%,
          #8b8f9c 100%
        );
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
        text-shadow: none;
      }

      .cursor {
        display: inline-block;
        width: 0.46em;
        height: 0.72em;
        margin-left: 0.12em;
        vertical-align: -0.04em;
        background: var(--fg);
        animation: blink 1.05s steps(1) infinite;
      }
      .cursor.rest {
        animation: blink 1.15s steps(1) infinite;
        opacity: 0.55;
      }

      .lede {
        margin: 1.6rem 0 0;
        max-width: 42ch;
        min-height: 1.2em;
        font-size: clamp(1rem, 3.2vw, 1.2rem);
        line-height: 1.6;
        color: #b9bcc7;
      }

      .links {
        display: flex;
        flex-wrap: wrap;
        gap: 0.55rem;
        margin-top: 2.2rem;
        opacity: 0;
        transform: translateY(8px);
        transition:
          opacity 0.8s ease,
          transform 0.8s ease;
      }
      body.typed .links {
        opacity: 1;
        transform: none;
      }

      .links a {
        display: inline-flex;
        align-items: baseline;
        gap: 0.6em;
        padding: 0.55rem 0.85rem;
        border: 1px solid var(--line);
        background: rgba(10, 11, 15, 0.35);
        backdrop-filter: blur(3px);
        color: var(--fg);
        text-decoration: none;
        font-size: 0.9rem;
        transition:
          border-color 0.25s ease,
          background 0.25s ease,
          transform 0.25s ease;
      }
      .links a:hover,
      .links a:focus-visible {
        border-color: rgba(231, 233, 240, 0.55);
        background: rgba(231, 233, 240, 0.06);
        transform: translateY(-2px);
        outline: none;
      }
      .l-note {
        color: var(--muted);
        font-size: 0.78rem;
      }
      .l-arrow {
        color: var(--muted);
        transition: transform 0.25s ease;
      }
      .links a:hover .l-arrow {
        transform: translateX(3px);
        color: var(--fg);
      }

      .footer {
        display: flex;
        gap: 0.6em;
        align-items: center;
        font-size: 0.72rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--faint);
      }
      .footer a {
        color: var(--muted);
        text-decoration: none;
        border-bottom: 1px solid transparent;
      }
      .footer a:hover {
        color: var(--fg);
        border-color: var(--line);
      }

      @keyframes blink {
        0%,
        45% {
          opacity: 1;
        }
        50%,
        95% {
          opacity: 0;
        }
        100% {
          opacity: 1;
        }
      }

      @media (prefers-reduced-motion: reduce) {
        .dot,
        .cursor {
          animation: none;
        }
        .links {
          opacity: 1;
          transform: none;
          transition: none;
        }
      }

      @media (max-width: 520px) {
        .loc {
          display: none;
        }
      }

      @media (max-width: 420px) {
        .l-note {
          display: none;
        }
      }
    </style>
  </body>
</html>
